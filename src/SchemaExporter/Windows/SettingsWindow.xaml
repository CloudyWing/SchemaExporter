<Window x:Class="CloudyWing.SchemaExporter.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="設定"
        Width="980"
        Height="720"
        MinWidth="900"
        MinHeight="620"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">
            <TabItem Header="Connections">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <ListBox Grid.Row="0"
                                 DisplayMemberPath="Name"
                                 ItemsSource="{Binding Connections}"
                                 SelectedItem="{Binding SelectedConnection}" />

                        <StackPanel Grid.Row="1"
                                    Orientation="Horizontal"
                                    Margin="0,12,0,0">
                            <Button Width="90"
                                    Padding="12,6"
                                    Content="新增"
                                    Click="AddConnectionButton_Click" />
                            <Button Width="90"
                                    Padding="12,6"
                                    Margin="12,0,0,0"
                                    Content="刪除"
                                    Click="RemoveConnectionButton_Click" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Column="2"
                          DataContext="{Binding SelectedConnection}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Margin="0,0,12,12"
                                   VerticalAlignment="Center"
                                   Text="連線名稱：" />
                        <TextBox Grid.Row="0"
                                 Grid.Column="1"
                                 Margin="0,0,0,12"
                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />

                        <TextBlock Grid.Row="1"
                                   Grid.Column="0"
                                   Margin="0,0,12,12"
                                   VerticalAlignment="Center"
                                   Text="資料庫類型：" />
                        <ComboBox Grid.Row="1"
                                  Grid.Column="1"
                                  Margin="0,0,0,12"
                                  ItemsSource="{Binding DataContext.DatabaseTypes, RelativeSource={RelativeSource AncestorType=Window}}"
                                  SelectedItem="{Binding DatabaseType}" />

                        <TextBlock Grid.Row="2"
                                   Grid.Column="0"
                                   Margin="0,0,12,12"
                                   VerticalAlignment="Top"
                                   Text="ConnectionString：" />
                        <TextBox Grid.Row="2"
                                 Grid.Column="1"
                                 Margin="0,0,0,12"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 TextWrapping="Wrap"
                                 Text="{Binding ConnectionString, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />

                        <TextBlock Grid.Row="3"
                                   Grid.Column="0"
                                   Margin="0,0,12,0"
                                   VerticalAlignment="Center"
                                   Text="匯出設定檔：" />
                        <TextBox Grid.Row="3"
                                 Grid.Column="1"
                                 Text="{Binding ExportProfileName, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                 ToolTip="留空表示使用預設設定檔。" />
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Profiles">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <ListBox Grid.Row="0"
                                 DisplayMemberPath="Name"
                                 ItemsSource="{Binding Profiles}"
                                 SelectedItem="{Binding SelectedProfile}" />

                        <StackPanel Grid.Row="1"
                                    Orientation="Horizontal"
                                    Margin="0,12,0,0">
                            <Button Width="90"
                                    Padding="12,6"
                                    Content="新增"
                                    Click="AddProfileButton_Click" />
                            <Button Width="90"
                                    Padding="12,6"
                                    Margin="12,0,0,0"
                                    Content="刪除"
                                    Click="RemoveProfileButton_Click" />
                        </StackPanel>
                    </Grid>

                    <ScrollViewer Grid.Column="2"
                                  VerticalScrollBarVisibility="Auto">
                        <Grid DataContext="{Binding SelectedProfile}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Margin="0,0,12,12"
                                       VerticalAlignment="Center"
                                       Text="設定檔名稱：" />
                            <TextBox Grid.Row="0"
                                     Grid.Column="1"
                                     Margin="0,0,0,12"
                                     Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Margin="0,0,12,12"
                                       VerticalAlignment="Center"
                                       Text="Include Views：" />
                            <CheckBox Grid.Row="1"
                                      Grid.Column="1"
                                      Margin="0,0,0,12"
                                      IsChecked="{Binding IncludeViews}" />

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Margin="0,0,12,12"
                                       VerticalAlignment="Top"
                                       Text="Include Schemas：" />
                            <TextBox Grid.Row="2"
                                     Grid.Column="1"
                                     Margin="0,0,0,12"
                                     AcceptsReturn="True"
                                     Height="90"
                                     VerticalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap"
                                     Text="{Binding IncludeSchemasText, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                     ToolTip="每行一筆 pattern。" />

                            <TextBlock Grid.Row="3"
                                       Grid.Column="0"
                                       Margin="0,0,12,12"
                                       VerticalAlignment="Top"
                                       Text="Exclude Schemas：" />
                            <TextBox Grid.Row="3"
                                     Grid.Column="1"
                                     Margin="0,0,0,12"
                                     AcceptsReturn="True"
                                     Height="90"
                                     VerticalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap"
                                     Text="{Binding ExcludeSchemasText, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                     ToolTip="每行一筆 pattern。" />

                            <TextBlock Grid.Row="4"
                                       Grid.Column="0"
                                       Margin="0,0,12,12"
                                       VerticalAlignment="Top"
                                       Text="Include Objects：" />
                            <TextBox Grid.Row="4"
                                     Grid.Column="1"
                                     Margin="0,0,0,12"
                                     AcceptsReturn="True"
                                     Height="90"
                                     VerticalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap"
                                     Text="{Binding IncludeObjectsText, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                     ToolTip="每行一筆 pattern。" />

                            <TextBlock Grid.Row="5"
                                       Grid.Column="0"
                                       Margin="0,0,12,0"
                                       VerticalAlignment="Top"
                                       Text="Exclude Objects：" />
                            <TextBox Grid.Row="5"
                                     Grid.Column="1"
                                     AcceptsReturn="True"
                                     Height="90"
                                     VerticalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap"
                                     Text="{Binding ExcludeObjectsText, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                     ToolTip="每行一筆 pattern。" />
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1"
                    Margin="0,16,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Width="90"
                    Padding="12,6"
                    IsCancel="True"
                    Content="取消" />
            <Button Width="90"
                    Padding="12,6"
                    Margin="12,0,0,0"
                    IsDefault="True"
                    Content="儲存"
                    Click="SaveButton_Click" />
        </StackPanel>
    </Grid>
</Window>